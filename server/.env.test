# Test Environment Configuration
NODE_ENV=test

# JWT Configuration (Test keys - not for production)
JWT_SECRET=test-super-secret-jwt-key-for-testing-only-do-not-use-in-production

# Database Configuration (Use in-memory database for tests)
MONGO_URI_TEST=mongodb://localhost/vibeblog_test

# Server Configuration
PORT=5001
CLIENT_URL=http://localhost:3000

# Mock API Keys (for testing)
NEWSAPI_KEY=test-newsapi-key
GROQ_API_KEY=test-groq-api-key
UNSPLASH_ACCESS_KEY=test-unsplash-access-key

# Image Storage Configuration
IMAGE_STORAGE_PROVIDER=local

# Admin Configuration
ADMIN_EMAILS=admin@test.com,test@admin.com